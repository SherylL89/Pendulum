# ── AI ────────────────────────────────────────────────────────────
# Claude: sentiment, image tagging, scraper extraction, newsletter classification, trend agent
ANTHROPIC_API_KEY=
# Embeddings (optional — deterministic fallback used if unset). Voyage recommended.
VOYAGE_API_KEY=
# OPENAI_API_KEY=

# ── Databases ─────────────────────────────────────────────────────
# Main Postgres (e.g. AWS RDS). Unset → local SQLite (dev).
DATABASE_URL=
# Vector DB with pgvector (e.g. Supabase). Unset → falls back to DATABASE_URL.
VECTOR_DATABASE_URL=

# ── Object storage (Cloudflare R2, S3-compatible) ─────────────────
R2_ENDPOINT=            # https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pendulum
R2_PUBLIC_URL=          # public bucket URL or custom domain

# ── Ingestion ─────────────────────────────────────────────────────
# JSON list of listing pages the agentic scraper reads daily:
# SCRAPE_SOURCES='[{"brand":"Zara","url":"https://...","category":"Woman - Accessories - Bag"}]'
SCRAPE_SOURCES=
# Dedicated newsletter inbox (subscribe it to competitor mailing lists)
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# ── Runtime ───────────────────────────────────────────────────────
ENABLE_SCHEDULER=0      # 1 = daily snapshot, 30-min IMAP poll, weekly trend agent
SEED_ON_START=0
CORS_ORIGINS=*          # comma-separated; set to your Vercel URL in prod
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Docker compose only ───────────────────────────────────────────
POSTGRES_USER=pendulum
POSTGRES_PASSWORD=pendulum
POSTGRES_DB=pendulum
